{
  "name": "cd-comic-reader",
  "version": "1.2.0",
  "description": "CD Comic Reader - Manga, Comic & Video Reader for Windows",
  "author": "CD Comic Reader",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node scripts/check-project.js",
    "smoke": "node scripts/e2e-smoke.js"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "build": {
    "appId": "com.cd.comicreader",
    "productName": "CD Comic Reader",
    "files": [
      "src/**/*",
      "assets/icon.ico",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
